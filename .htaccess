<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # This app is deployed inside the public website tree. Only the app
    # subdomain should be allowed to execute it.
    RewriteCond %{HTTP_HOST} !^app\.toquran\.org$ [NC]
    RewriteRule ^ - [F,L]

    # Shared-hosting root entry: Laravel asset() URLs should resolve to
    # public/ even when Hostinger serves the app from the project root.
    RewriteCond %{DOCUMENT_ROOT}/public/assets/$1 -f
    RewriteRule ^assets/(.+)$ public/assets/$1 [L]

    RewriteCond %{DOCUMENT_ROOT}/public/images/$1 -f
    RewriteRule ^images/(.+)$ public/images/$1 [L]

    RewriteCond %{DOCUMENT_ROOT}/public/pwa/$1 -f
    RewriteRule ^pwa/(.+)$ public/pwa/$1 [L]

    RewriteCond %{DOCUMENT_ROOT}/public/build/$1 -f
    RewriteRule ^build/(.+)$ public/build/$1 [L]

    # Shared-hosting root entry: Laravel still generates /storage/... URLs.
    # Serve only files that exist through the public storage symlink.
    RewriteCond %{DOCUMENT_ROOT}/public/storage/$1 -f
    RewriteRule ^storage/(.+)$ public/storage/$1 [L]

    # Block direct web access to framework/source directories when Hostinger
    # serves the app from the project root instead of public/.
    RewriteRule ^(?:app|bootstrap|config|database|docs|lang|resources|routes|scripts|specs|storage|tests|tmp|vendor|node_modules)(?:/|$) - [F,L]
    RewriteRule ^(?:composer\.(?:json|lock)|package(?:-lock)?\.json|yarn\.lock|vite\.config\.js|phpunit\.xml|artisan|docker-compose\.yml|to_quran_adhkar_dua_banks\.md|.*\.(?:md|sql|log|bak)|\.env(?:\..*)?|\.git(?:/|ignore|attributes)?|\.editorconfig)$ - [F,L]

    # Handle Authorization and XSRF headers.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect trailing slashes if not a folder.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send requests to the front controller.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
